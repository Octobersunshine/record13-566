DATABASE_URL=sqlite:./medical_chat.db?mode=rwc
HOST=0.0.0.0
PORT=3000
RUST_LOG=info,medical_chat=debug

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/gif,image/webp,image/bmp

LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SECS=30
USE_TEMPLATE_FALLBACK=true
